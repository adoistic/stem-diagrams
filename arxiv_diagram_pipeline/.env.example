# Copy this file to .env and fill in your keys.
# The download stage works without any keys.

# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# xiaomi/mimo-v2.5-pro is TEXT-ONLY on OpenRouter; use the multimodal sibling
# xiaomi/mimo-v2.5 (no "-pro") for page analysis + diagram labeling.
OPENROUTER_MODEL=xiaomi/mimo-v2.5

# Cheap fast vision model that pre-screens pages before OPENROUTER_MODEL
# confirms; big cost/latency win with unchanged final gate quality.
SCREEN_MODEL=bytedance-seed/seed-1.6-flash

# https://console.mistral.ai/api-keys  (used for Mistral OCR)
MISTRAL_API_KEY=

# Optional: point pipeline output at an external/large drive instead of ./data
# DATA_DIR=/Volumes/One Touch/stem_diagrams_data
